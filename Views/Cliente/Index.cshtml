@model IEnumerable<Cliente>
@{
    ViewData["Title"] = "Clientes Cadastrados";
}

<div class="container py-3">
    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white d-flex align-items-center justify-content-between">
            <h5 class="card-title mb-0">Clientes Cadastrados</h5>
            <a asp-action="Cadastro" class="btn btn-light btn-sm">
                Cadastrar Novo Cliente
            </a>
        </div>
        <div class="card-body">
            @if (Model == null || !Model.Any())
            {
                <div class="alert alert-info text-center" role="alert">
                    Nenhum cliente cadastrado até o momento.
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-striped table-hover align-middle mb-0">
                        <thead>
                            <tr>
                                <th scope="col" style="width: 80px;">Foto</th>
                                <th scope="col">Nome / Razão Social</th>
                                <th scope="col">CPF / CNPJ</th>
                                <th scope="col">Cidade - UF</th>
                                <th scope="col">Data Nasc.</th>
                                <th scope="col" class="text-end" style="width: 200px;">Ações</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var cliente in Model)
                            {
                                <tr>
                                    <td>
                                        @if (!string.IsNullOrEmpty(cliente.ImagemCaminho))
                                        {
                                            <img src="@cliente.ImagemCaminho" alt="Avatar" class="rounded-circle border" style="width: 40px; height: 40px; object-fit: cover;" />
                                        }
                                        else
                                        {
                                            <div class="rounded-circle bg-secondary text-white d-flex align-items-center justify-content-center border" style="width: 40px; height: 40px; font-weight: bold; font-size: 0.9rem;">
                                                @cliente.Nome.Substring(0, Math.Min(cliente.Nome.Length, 2)).ToUpper()
                                            </div>
                                        }
                                    </td>
                                    <td>
                                        <div class="fw-bold">@cliente.Nome</div>
                                        @if (!string.IsNullOrEmpty(cliente.NomeFantasia))
                                        {
                                            <small class="text-muted">@cliente.NomeFantasia</small>
                                        }
                                    </td>
                                    <td>@cliente.CodigoFiscal</td>
                                    <td>@cliente.Cidade - @cliente.Estado.ToUpper()</td>
                                    <td>@cliente.DataNascimento.ToString("dd/MM/yyyy")</td>
                                    <td class="text-end">
                                        <div class="d-flex justify-content-end gap-2">
                                            @if (User.Identity != null && User.Identity.IsAuthenticated && (cliente.CodigoFiscal == User.Identity.Name || User.Identity.Name == "Admin"))
                                            {
                                                <a asp-action="Editar" asp-route-id="@cliente.Id" class="btn btn-primary btn-sm">
                                                    Editar
                                                </a>
                                                <form asp-action="Excluir" asp-route-id="@cliente.Id" method="post" onsubmit="return confirm('Tem certeza que deseja excluir este cliente?');" class="d-inline">
                                                    <button type="submit" class="btn btn-danger btn-sm">
                                                        Excluir
                                                    </button>
                                                </form>
                                            }
                                            else
                                            {
                                                <span class="text-muted small">Apenas leitura</span>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>
